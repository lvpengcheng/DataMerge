# 本地AI配置（如Ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=120

# AI提供者选择
# 支持的提供者: openai, claude, deepseek, ollama, local
AI_PROVIDER=claude
# 校验规则生成专用AI提供者（可选，不设置则使用AI_PROVIDER）
# 用于生成数据校验规则，可以使用更便宜/快速的模型
# VALIDATION_AI_PROVIDER=claude

# AI请求限制
AI_MAX_RETRIES=30
AI_RETRY_DELAY=20
AI_RATE_LIMIT=10

# 数据库配置
# 支持 PostgreSQL / MySQL / SQLite，修改 DATABASE_URL 即可切换
# PostgreSQL 示例: postgresql+psycopg2://user:pass@host:5432/dbname
# MySQL 示例:     mysql+pymysql://user:pass@host:3306/dbname?charset=utf8mb4
# SQLite 示例:    sqlite:///./data.db

# --- PostgreSQL（当前使用） ---
PG_HOST=192.168.10.139
PG_PORT=35432
PG_USER=rex
PG_PASSWORD=Lvkuuki1984
PG_DATABASE=datamergeTest
DATABASE_URL=postgresql+psycopg2://rex:Lvkuuki1984@192.168.10.139:35432/datamergeTest

# --- MySQL（备用，切换时修改 DATABASE_URL 即可） ---
MYSQL_HOST=192.168.10.139
MYSQL_PORT=13306
MYSQL_USER=root
MYSQL_PASSWORD=Lvkuuki1984
MYSQL_DATABASE=datamerge
#DATABASE_URL=mysql+pymysql://root:Lvkuuki1984@192.168.10.139:13306/datamerge?charset=utf8mb4

# JWT认证配置
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis配置（用于任务队列）
REDIS_URL=redis://localhost:6379/0

# 应用配置
DEBUG=True
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1

# 文件存储配置
MAX_UPLOAD_SIZE=104857600  # 100MB
ALLOWED_FILE_TYPES=.xlsx,.xls,.txt,.md,.pdf,.doc,.docx

# 训练配置
MAX_TRAINING_ITERATIONS=1
MIN_MATCH_SCORE=0.4

# 训练成功阈值配置
# 训练成功的最低分数阈值（0.0-1.0），达到此分数认为训练成功
TRAINING_SUCCESS_THRESHOLD=0.5
# 完美匹配阈值（0.0-1.0），达到此分数提前结束训练
TRAINING_PERFECT_THRESHOLD=0.96

# 智能匹配配置
# 表头结构相似度阈值（0.0~1.0），低于此值不自动配对，交给AI处理
HEADER_SIMILARITY_THRESHOLD=0.9

# 模块化生成配置
# auto: 根据规则复杂度自动判断
# true: 强制使用模块化生成
# false: 禁用模块化生成
USE_MODULAR_GENERATION=true

# 公式模式配置
# true: 使用Excel公式模式（基础列填数据，计算列用Excel公式）
# false: 使用传统Python计算模式
USE_FORMULA_MODE=true

# 公式模式续写轮数（1=不续写，一次性生成；默认15）
FORMULA_MAX_ROUNDS=1

# 公式模式验证步骤（true=生成后AI自审修正，false=跳过验证）
FORMULA_VERIFY_CODE=true

# 沙箱配置
CODE_SANDBOX_TIMEOUT=3000
CODE_SANDBOX_MAX_MEMORY=

# Excel解析配置
# Excel文件最大列数限制（防止读取超大文件耗费资源）
EXCEL_MAX_COLUMNS=150
# 是否只读取激活的Sheet（true=只读激活Sheet，false=读取所有Sheet）
EXCEL_READ_ACTIVE_SHEET_ONLY=true
# 表头匹配相似度阈值（0.0-1.0），低于此值直接报错，高于此值进行映射
HEADER_MATCH_THRESHOLD=0.85

# 规则整理配置
# 设计文档单个文件最大字符数（超出部分截断，防止超出AI上下文窗口）
RULE_ORGANIZE_MAX_DOC_CHARS=30000

