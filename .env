# Anthropic (Claude)配置
ANTHROPIC_API_KEY=sk-Fj1hKTsmPBW01Y4r7hA3fdf33mauOiHAPwRl5wPIpQ27XVHY
ANTHROPIC_BASE_URL= https://yibuapi.com
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=64000
ANTHROPIC_TEMPERATURE=0.1
