# ==================== AI API配置 ====================

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1  # 可自定义API端点
OPENAI_MODEL=gpt-4-turbo-preview  # 可选: gpt-4, gpt-4-turbo, gpt-3.5-turbo
OPENAI_TIMEOUT=60  # API超时时间(秒)
OPENAI_MAX_TOKENS=4000  # 最大生成token数

# Anthropic (Claude)配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229  # 可选: claude-3-opus, claude-3-haiku
ANTHROPIC_MAX_TOKENS=4000
ANTHROPIC_TEMPERATURE=0.1  # 温度参数，越低越稳定

# DeepSeek配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat  # 可选: deepseek-coder, deepseek-reasoner
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_TOKENS=4000

# 本地AI配置（如Ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2  # 或 codellama, mistral 等
OLLAMA_TIMEOUT=120

# AI提供者选择
# 支持的提供者: openai, claude, deepseek, ollama, local
AI_PROVIDER=openai
AI_FALLBACK_PROVIDER=local  # 主提供者失败时的备用提供者

# AI请求限制
AI_MAX_RETRIES=3
AI_RETRY_DELAY=2  # 重试延迟(秒)
AI_RATE_LIMIT=10  # 每分钟最大请求数

# 数据库配置
DATABASE_URL=sqlite:///./data.db

# Redis配置（用于任务队列）
REDIS_URL=redis://localhost:6379/0

# 应用配置
DEBUG=True
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1

# 文件存储配置
MAX_UPLOAD_SIZE=104857600  # 100MB
ALLOWED_FILE_TYPES=.xlsx,.xls,.txt,.md,.pdf,.doc,.docx

# 训练配置
MAX_TRAINING_ITERATIONS=2
MIN_MATCH_SCORE=0.7

# 沙箱配置
CODE_SANDBOX_TIMEOUT=300
CODE_SANDBOX_MAX_MEMORY=1024